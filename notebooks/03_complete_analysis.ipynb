    "# 📊 Complete Economic Analysis\n",
    "## World Bank Data Project\n",
    "**MBA Data Analytics | Mizoram University**\n",
    "\n",
    "This notebook performs end-to-end analysis:\n",
    "1. Load data\n",
    "2. Clean and prepare\n",
    "3. Exploratory analysis\n",
    "4. Create visualizations\n",
    "5. Save all outputs for portfolio"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📥 1. Load Data\n",
    "(Reusing code from 01_data_download.ipynb)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Import libraries\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import sys\n",
    "import os\n",
    "from datetime import datetime\n",
    "\n",
    "# Import our modules\n",
    "sys.path.append('..')\n",
    "from src.data_loader import load_world_bank_data\n",
    "from src.data_cleaner import clean_economic_data\n",
    "from src.visualization import generate_all_visualizations\n",
    "\n",
    "# Create output directories\n",
    "os.makedirs('../outputs/figures', exist_ok=True)\n",
    "os.makedirs('../outputs/dashboards', exist_ok=True)\n",
    "os.makedirs('../outputs/reports', exist_ok=True)\n",
    "\n",
    "print('✅ Setup complete')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data\n",
    "print(\"📥 Loading data...\")\n",
    "df_raw = load_world_bank_data()\n",
    "print(f\"✅ Loaded {len(df_raw)} rows\")\n",
    "df_raw.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🧹 2. Clean Data\n",
    "(Reusing code from 02_data_cleaning.ipynb)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Clean data\n",
    "print(\"🧹 Cleaning data...\")\n",
    "df = clean_economic_data(df_raw)\n",
    "print(f\"✅ Cleaned {len(df)} rows\")\n",
    "\n",
    "# Save cleaned data\n",
    "df.to_csv('../outputs/cleaned_data.csv', index=False)\n",
    "print(\"💾 Saved: outputs/cleaned_data.csv\")\n",
    "\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📊 3. Summary Statistics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Overall statistics\n",
    "summary = df.describe()\n",
    "summary.to_csv('../outputs/reports/summary_statistics.csv')\n",
    "print(\"📈 Summary Statistics:\")\n",
    "display(summary)\n",
    "\n",
    "# Country rankings\n",
    "rankings = df.groupby('country').agg({\n",
    "    'gdp_growth': ['mean', 'std', 'min', 'max'],\n",
    "    'edu_expenditure': 'mean',\n",
    "    'life_expectancy': 'mean'\n",
    "}).round(2)\n",
    "rankings.columns = ['_'.join(col).strip() for col in rankings.columns.values]\n",
    "rankings = rankings.sort_values('gdp_growth_mean', ascending=False)\n",
    "rankings.to_csv('../outputs/reports/country_rankings.csv')\n",
    "print(\"\\n🏆 Top 10 Countries by Growth:\")\n",
    "display(rankings.head(10))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📈 4. Create Visualizations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Set style\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\n",
    "sns.set_palette(\"husl\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4.1 GDP Growth Trends\n",
    "plt.figure(figsize=(14, 6))\n",
    "\n",
    "top_countries = df.groupby('country')['gdp_growth'].mean().nlargest(8).index\n",
    "for country in top_countries:\n",
    "    country_data = df[df['country'] == country].sort_values('year')\n",
    "    plt.plot(country_data['year'], country_data['gdp_growth'], \n",
    "            marker='o', linewidth=2, label=country)\n",
    "\n",
    "plt.axvspan(2019.5, 2020.5, alpha=0.2, color='red', label='COVID-19')\n",
    "plt.title('GDP Growth Trends - Top 8 Economies', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Year')\n",
    "plt.ylabel('GDP Growth (%)')\n",
    "plt.legend(bbox_to_anchor=(1.05, 1))\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/figures/gdp_trends.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"💾 Saved: outputs/figures/gdp_trends.png\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4.2 Education vs Growth\n",
    "plt.figure(figsize=(12, 6))\n",
    "\n",
    "latest_year = df['year'].max()\n",
    "recent = df[df['year'] == latest_year]\n",
    "\n",
    "scatter = plt.scatter(recent['edu_expenditure'], recent['gdp_growth'],\n",
    "                     c=recent['gdp_growth'], cmap='RdYlGn', s=200, alpha=0.6)\n",
    "\n",
    "for idx, row in recent.iterrows():\n",
    "    plt.annotate(row['country'], (row['edu_expenditure'], row['gdp_growth']),\n",
    "                fontsize=8, alpha=0.7)\n",
    "\n",
    "plt.colorbar(scatter, label='GDP Growth (%)')\n",
    "plt.title(f'Education Spending vs GDP Growth ({latest_year})', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Education Expenditure (% of GDP)')\n",
    "plt.ylabel('GDP Growth (%)')\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/figures/education_vs_growth.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"💾 Saved: outputs/figures/education_vs_growth.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🌐 5. Interactive Dashboard"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import plotly.express as px\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "# Create interactive line chart\n",
    "fig = px.line(df, x='year', y='gdp_growth', color='country',\n",
    "              title='Interactive GDP Growth Trends',\n",
    "              labels={'gdp_growth': 'GDP Growth (%)', 'year': 'Year'})\n",
    "\n",
    "fig.update_layout(hovermode='x unified', height=500)\n",
    "fig.write_html('../outputs/dashboards/gdp_trends_interactive.html')\n",
    "print(\"💾 Saved: outputs/dashboards/gdp_trends_interactive.html\")\n",
    "\n",
    "# Show in notebook\n",
    "fig.show()"
   ]
